# Example environment variables for local development
# Copy this to .env and fill values. NEVER commit .env to source control.

# Cesium ion access token (for 3D terrain/imagery)
CESIUM_ION_TOKEN=

# Optional AI provider keys
GITHUB_TOKEN=
OPENAI_API_KEY=
GROQ_API_KEY=

# Flask settings
FLASK_ENV=development
SECRET_KEY=replace-with-random-secret